{
  "name": "gattai-merge",
  "version": "3.4.1",
  "description": "High-performance deep merge utility with structural sharing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "prepublishOnly": "npm run build && npm test",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "array",
    "buffer",
    "circular-reference",
    "date",
    "deep",
    "deep-merge",
    "descriptor",
    "immutable",
    "map",
    "merge",
    "merge-array",
    "merge-array-deep",
    "merge-buffer",
    "merge-date",
    "merge-deep",
    "merge-map",
    "merge-object",
    "merge-object-deep",
    "merge-regexp",
    "merge-set",
    "object",
    "property-descriptor",
    "regexp",
    "set",
    "typescript"
  ],
  "author": "Yusuke Kamiyamane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y14e/gattai-merge.git"
  },
  "bugs": {
    "url": "https://github.com/y14e/gattai-merge/issues"
  },
  "homepage": "https://github.com/y14e/gattai-merge#readme",
  "devDependencies": {
    "bun-types": "latest",
    "bunshin-clone": "^1.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "deepmerge": "^4.3.1",
    "deepmerge-ts": "^7.1.5",
    "gattai-merge": "^3.4.0",
    "immer": "^11.1.8",
    "lodash.merge": "^4.6.2",
    "tinybench": "^6.0.2"
  }
}
